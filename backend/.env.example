# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/auth.db

# ── Security ─────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Groq AI (required) ──────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=30

# ── Per-feature model overrides (optional) ───────────────
EMAIL_GROQ_MODEL=llama-3.1-8b-instant
EMAIL_GROQ_TEMPERATURE=0.5
EMAIL_GROQ_MAX_TOKENS=400
EMAIL_ASSIST_GROQ_MODEL=llama-3.1-8b-instant
EMAIL_ASSIST_GROQ_TEMPERATURE=0.35
EMAIL_ASSIST_GROQ_MAX_TOKENS=650
BLOG_GROQ_MODEL=llama-3.1-8b-instant
BLOG_GROQ_TEMPERATURE=0.4
BLOG_GROQ_MAX_TOKENS=900
CHAT_GROQ_MODEL=llama-3.1-8b-instant
CHAT_GROQ_TEMPERATURE=0.7
CHAT_GROQ_MAX_TOKENS=800

# ── Google OAuth ─────────────────────────────────────────
# Get your client ID at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
